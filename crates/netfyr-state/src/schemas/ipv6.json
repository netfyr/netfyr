{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ipv6",
  "description": "IPv6 configuration fragment — defines a single top-level 'ipv6' property",
  "type": "object",
  "properties": {
    "ipv6": {
      "type": "object",
      "additionalProperties": false,
      "description": "IPv6 configuration",
      "x-netfyr-writable": true,
      "x-netfyr-keep-when-absent": true,
      "properties": {
        "addresses": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$"
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["address"],
                "properties": {
                  "address": {
                    "type": "string",
                    "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$"
                  },
                  "valid_lft": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Valid lifetime in seconds"
                  },
                  "preferred_lft": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Preferred lifetime in seconds"
                  },
                  "dad_state": {
                    "type": "string",
                    "enum": ["tentative", "preferred", "deprecated", "dadfailed"],
                    "description": "Duplicate Address Detection state"
                  }
                }
              }
            ]
          },
          "description": "IPv6 addresses assigned to the interface",
          "x-netfyr-writable": true,
          "x-netfyr-comparison-keys": ["address"]
        },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["destination"],
            "properties": {
              "destination": {
                "type": "string",
                "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$",
                "description": "Route destination in CIDR format"
              },
              "gateway": {
                "type": "string",
                "pattern": "^[0-9a-fA-F:.]+$",
                "description": "Gateway IP address"
              },
              "metric": {
                "type": "integer",
                "minimum": 0,
                "description": "Route metric (lower is preferred)"
              },
              "protocol": {
                "type": "string",
                "description": "Route protocol (kernel, static, dhcp, etc.)"
              },
              "mtu": {
                "type": "integer",
                "minimum": 0,
                "description": "Route MTU in bytes"
              },
              "table": {
                "type": "integer",
                "minimum": 0,
                "maximum": 4294967295,
                "description": "Routing table ID (default 254 = main)"
              },
              "tos": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255,
                "description": "Type of Service (TOS/DSCP) filter"
              }
            }
          },
          "description": "IPv6 routes via this interface",
          "x-netfyr-writable": true
        },
        "dns_servers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "IPv6 DNS server addresses (from RDNSS or DHCPv6)",
          "x-netfyr-writable": false
        },
        "dns_search": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "DNS search domains (from DNSSL or DHCPv6)",
          "x-netfyr-writable": false
        },
        "nat64_prefix": {
          "type": "string",
          "description": "NAT64 prefix (from PREF64 RA option) in CIDR format",
          "x-netfyr-writable": false
        },
        "link_local": {
          "type": "string",
          "enum": ["eui64", "none"],
          "description": "Link-local address generation method (default: eui64)",
          "x-netfyr-writable": true,
          "x-netfyr-keep-when-absent": true
        },
        "dad_transmits": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of DAD NS probes (0 = disable DAD; default: kernel default, typically 1)",
          "x-netfyr-writable": true,
          "x-netfyr-keep-when-absent": true
        }
      }
    }
  }
}

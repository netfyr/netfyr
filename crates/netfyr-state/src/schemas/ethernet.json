{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ethernet",
  "description": "Ethernet interface entity",
  "type": "object",
  "additionalProperties": false,
  "x-netfyr-inherit": ["ip", "link"],
  "properties": {
    "speed": {
      "type": "integer",
      "minimum": 0,
      "description": "Link speed in Mbps",
      "x-netfyr-writable": false
    },
    "driver": {
      "type": "string",
      "description": "Kernel driver name",
      "x-netfyr-writable": false
    }
  }
}

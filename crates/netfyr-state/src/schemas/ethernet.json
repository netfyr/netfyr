{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ethernet",
  "description": "Ethernet interface entity",
  "type": "object",
  "additionalProperties": false,
  "x-netfyr-inherit": ["ip", "link"],
  "properties": {
    "ethernet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Ethernet-specific properties",
      "x-netfyr-writable": false,
      "properties": {
        "speed": {
          "type": "integer",
          "minimum": 0,
          "description": "Negotiated link speed in Mbps",
          "x-netfyr-writable": false
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ip",
  "description": "IP configuration properties shared across interface types",
  "type": "object",
  "properties": {
    "addresses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$"
      },
      "description": "IP addresses assigned to the interface",
      "x-netfyr-writable": true,
      "x-netfyr-comparison-keys": ["address"]
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["destination"],
        "properties": {
          "destination": {
            "type": "string",
            "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$",
            "description": "Route destination in CIDR format"
          },
          "gateway": {
            "type": "string",
            "pattern": "^[0-9a-fA-F:.]+$",
            "description": "Gateway IP address"
          },
          "metric": {
            "type": "integer",
            "minimum": 0,
            "description": "Route metric (lower is preferred)"
          },
          "protocol": {
            "type": "string",
            "description": "Route protocol (kernel, static, dhcp, etc.)"
          }
        }
      },
      "description": "Routes via this interface",
      "x-netfyr-writable": true
    },
    "dns_servers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "DNS server addresses",
      "x-netfyr-writable": false
    }
  }
}
